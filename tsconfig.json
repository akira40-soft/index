{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": [
            "ES2022",
            "dom"
        ],
        "types": [],
        "allowJs": true,
        "checkJs": false,
        "noEmit": false,
        "outDir": "./dist",
        "rootDir": "./",
        "strict": false,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": [
        "**/*.d.ts",
        "modules/**/*.ts",
        "index.ts"
    ]
}